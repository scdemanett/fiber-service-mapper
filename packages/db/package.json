{
  "name": "@fsm/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "npx prisma generate --config prisma.config.ts",
    "db:push": "npx prisma db push --config prisma.config.ts",
    "postdb:push": "node prisma/apply-indexes.mjs",
    "db:migrate": "npx prisma migrate dev --config prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.1",
    "prisma": "^7.7.0",
    "typescript": "^6.0.2"
  }
}
